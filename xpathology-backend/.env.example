# X-Pathology Backend Environment Variables
# Copy this to .env and fill in your values

# Required: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Hugging Face token (for private repos)
HF_TOKEN=

# Optional: CORS allowed origins (comma-separated, default: * for dev)
# Example for production: https://your-frontend-domain.vercel.app
ALLOWED_ORIGINS=*

# Optional: Server host and port
HOST=0.0.0.0
PORT=8000
